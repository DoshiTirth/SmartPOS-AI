<Window x:Class="SmartPOS.Desktop.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="SmartPOS AI — POS Terminal"
        Height="768" Width="1280"
        MinHeight="768" MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="{StaticResource BrushBackground}"
            BorderBrush="{StaticResource BrushBorder}"
            BorderThickness="1"
            CornerRadius="12">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════ -->
            <!-- TOP BAR                                 -->
            <!-- ═══════════════════════════════════════ -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo + Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="CashRegister"
                                                   Width="20" Height="20"
                                                   Foreground="{StaticResource BrushAccent}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                        <TextBlock Text="SmartPOS AI"
                                   Style="{StaticResource TextBody}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Border Background="{StaticResource BrushAccentMuted}"
                                CornerRadius="4"
                                Padding="6,2"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="POS Terminal"
                                       Foreground="{StaticResource BrushAccent}"
                                       FontSize="11"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <!-- Center - Cashier Info -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="Account"
                                                   Width="14" Height="14"
                                                   Foreground="{StaticResource BrushTextMuted}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding CashierName}"
                                   Style="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>
                        <iconPacks:PackIconMaterial Kind="Clock"
                                                   Width="14" Height="14"
                                                   Foreground="{StaticResource BrushTextMuted}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding CurrentTime}"
                                   Style="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Right - Actions -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource ButtonSecondary}"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                Command="{Binding LogoutCommand}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Logout"
                                                           Width="14" Height="14"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,6,0"/>
                                <TextBlock Text="Logout" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button Width="32" Height="32"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource BrushTextMuted}"
                                Cursor="Hand"
                                FontSize="14"
                                Click="CloseButton_Click">✕</Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════ -->
            <!-- MAIN CONTENT                            -->
            <!-- ═══════════════════════════════════════ -->
            <Grid Grid.Row="1" Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Product Search + Grid -->
                <Grid Grid.Column="0" Margin="16,16,8,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search Bar -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushSurface}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,0"
                            Margin="0,0,0,12"
                            Height="44">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <iconPacks:PackIconMaterial Grid.Column="0"
                                                       Kind="Magnify"
                                                       Width="16" Height="16"
                                                       Foreground="{StaticResource BrushTextMuted}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource BrushTextPrimary}"
                                     FontSize="14"
                                     VerticalAlignment="Center"
                                     CaretBrush="{StaticResource BrushAccent}"/>
                            <TextBlock Grid.Column="1"
                                       Text="Search products or scan barcode..."
                                       Foreground="{StaticResource BrushTextMuted}"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SearchQuery}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding ProductCount, StringFormat='{}{0} items'}"
                                       Style="{StaticResource TextMuted}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Product Grid -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FilteredProducts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="160" Height="100"
                                            Margin="0,0,8,8"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.AddToCartCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Border Background="{StaticResource BrushSurface}"
                                                BorderBrush="{StaticResource BrushBorder}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12"
                                                Width="160" Height="100">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource BrushWarning}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0"
                                                           Text="{Binding ProductName}"
                                                           Foreground="{StaticResource BrushTextPrimary}"
                                                           FontSize="13"
                                                           FontWeight="Medium"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Top"/>
                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding UnitPrice, StringFormat='${0:F2}'}"
                                                           Foreground="{StaticResource BrushAccent}"
                                                           FontSize="15"
                                                           FontWeight="Bold"/>
                                                <TextBlock Grid.Row="2"
                                                           Text="{Binding StockQuantity, StringFormat='Stock: {0}'}"
                                                           Style="{StaticResource TextMuted}"/>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- RIGHT: Cart + Payment -->
                <Border Grid.Column="1"
                        Background="{StaticResource BrushSurface}"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1,0,0,0"
                        Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Cart Header -->
                        <Border Grid.Row="0"
                                BorderBrush="{StaticResource BrushBorder}"
                                BorderThickness="0,0,0,1"
                                Padding="16,12">
                            <Grid>
                                <TextBlock Text="Current Order"
                                           Style="{StaticResource TextHeading}"
                                           FontSize="16"/>
                                <Button Content="Clear"
                                        Style="{StaticResource ButtonDanger}"
                                        Padding="10,4"
                                        FontSize="12"
                                        HorizontalAlignment="Right"
                                        Command="{Binding ClearCartCommand}"/>
                            </Grid>
                        </Border>

                        <!-- Cart Items -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      Margin="0">
                            <ItemsControl ItemsSource="{Binding CartItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BrushBorder}"
                                                BorderThickness="0,0,0,1"
                                                Padding="16,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="{Binding ProductName}"
                                                           Style="{StaticResource TextBody}"
                                                           FontWeight="Medium"/>
                                                <TextBlock Grid.Row="0" Grid.Column="1"
                                                           Text="{Binding LineTotal, StringFormat='${0:F2}'}"
                                                           Foreground="{StaticResource BrushAccent}"
                                                           FontWeight="Bold"
                                                           FontSize="14"/>

                                                <!-- Quantity Controls -->
                                                <StackPanel Grid.Row="1" Grid.Column="0"
                                                            Orientation="Horizontal"
                                                            Margin="0,4,0,0">
                                                    <Button Content="−"
                                                            Width="24" Height="24"
                                                            Style="{StaticResource ButtonSecondary}"
                                                            Padding="0"
                                                            FontSize="14"
                                                            Command="{Binding DataContext.DecreaseQuantityCommand,
                                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"/>
                                                    <TextBlock Text="{Binding Quantity}"
                                                               Foreground="{StaticResource BrushTextPrimary}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               Margin="10,0"/>
                                                    <Button Content="+"
                                                            Width="24" Height="24"
                                                            Style="{StaticResource ButtonSecondary}"
                                                            Padding="0"
                                                            FontSize="14"
                                                            Command="{Binding DataContext.IncreaseQuantityCommand,
                                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>

                                                <TextBlock Grid.Row="1" Grid.Column="1"
                                                           Text="{Binding UnitPrice, StringFormat='${0:F2} each'}"
                                                           Style="{StaticResource TextMuted}"
                                                           VerticalAlignment="Bottom"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Order Summary -->
                        <Border Grid.Row="2"
                                BorderBrush="{StaticResource BrushBorder}"
                                BorderThickness="0,1,0,1"
                                Padding="16,12">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="Subtotal"
                                               Style="{StaticResource TextSubheading}"/>
                                    <TextBlock Text="{Binding Subtotal, StringFormat='${0:F2}'}"
                                               Style="{StaticResource TextSubheading}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="Tax (13%)"
                                               Style="{StaticResource TextMuted}"/>
                                    <TextBlock Text="{Binding TaxAmount, StringFormat='${0:F2}'}"
                                               Style="{StaticResource TextMuted}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Total"
                                               Foreground="{StaticResource BrushTextPrimary}"
                                               FontSize="18"
                                               FontWeight="Bold"/>
                                    <TextBlock Text="{Binding TotalAmount, StringFormat='${0:F2}'}"
                                               Foreground="{StaticResource BrushAccent}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Payment Section -->
                        <StackPanel Grid.Row="3" Margin="16,12">

                            <!-- Payment Method -->
                            <TextBlock Text="Payment Method"
                                       Style="{StaticResource TextMuted}"
                                       Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <RadioButton Content="Cash"
                                             IsChecked="{Binding IsCash}"
                                             Foreground="{StaticResource BrushTextPrimary}"
                                             Margin="0,0,16,0"/>
                                <RadioButton Content="Card"
                                             IsChecked="{Binding IsCard}"
                                             Foreground="{StaticResource BrushTextPrimary}"
                                             Margin="0,0,16,0"/>
                                <RadioButton Content="Other"
                                             IsChecked="{Binding IsOther}"
                                             Foreground="{StaticResource BrushTextPrimary}"/>
                            </StackPanel>

                            <!-- Charge Button -->
                            <Button Style="{StaticResource ButtonPrimary}"
                                    Height="52"
                                    FontSize="16"
                                    Command="{Binding ProcessPaymentCommand}"
                                    IsEnabled="{Binding CanProcessPayment}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="CreditCard"
                                                               Width="18" Height="18"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding TotalAmount, StringFormat='Charge ${0:F2}'}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════ -->
            <!-- STATUS BAR                              -->
            <!-- ═══════════════════════════════════════ -->
            <Border Grid.Row="2"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,1,0,0"
                    Padding="16,0">
                <Grid>
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource TextMuted}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TransactionCount, StringFormat='Transactions today: {0}'}"
                               Style="{StaticResource TextMuted}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>