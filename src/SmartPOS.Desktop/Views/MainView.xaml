<Window x:Class="SmartPOS.Desktop.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:views="clr-namespace:SmartPOS.Desktop.Views"
        Title="SmartPOS AI"
        Height="768" Width="1280"
        MinHeight="768" MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="{StaticResource BrushBackground}"
            BorderBrush="{StaticResource BrushBorder}"
            BorderThickness="1"
            CornerRadius="12">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,0,1,0"
                    CornerRadius="12,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Row="0" Margin="20,24,20,32">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <iconPacks:PackIconMaterial Kind="CashRegister"
                                                       Width="22" Height="22"
                                                       Foreground="{StaticResource BrushAccent}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                            <TextBlock Text="SmartPOS AI"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding CashierRole}"
                                   Style="{StaticResource TextMuted}"
                                   Margin="32,0,0,0"/>
                    </StackPanel>

                    <!-- Navigation Items -->
                    <StackPanel Grid.Row="1" Margin="12,0">

                        <!-- POS Terminal -->
                        <Button Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="POS"
                                Tag="{Binding CurrentView}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="CashRegister"
                                                           Width="16" Height="16"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,12,0"/>
                                <TextBlock Text="POS Terminal" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Inventory - Manager/Admin only -->
                        <Button Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="Inventory"
                                Visibility="{Binding IsManager, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="PackageVariant"
                                                           Width="16" Height="16"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,12,0"/>
                                <TextBlock Text="Inventory" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Transactions - Manager/Admin only -->
                        <Button Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="Transactions"
                                Visibility="{Binding IsManager, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ReceiptText"
                                                           Width="16" Height="16"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,12,0"/>
                                <TextBlock Text="Transactions" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Dashboard - Manager/Admin only -->
                        <Button Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="Dashboard"
                                Visibility="{Binding IsManager, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ChartLine"
                                                           Width="16" Height="16"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,12,0"/>
                                <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>

                    <!-- Bottom - User Info + Logout -->
                    <Border Grid.Row="2"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="0,1,0,0"
                            Padding="16,12"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                                <iconPacks:PackIconMaterial Kind="Account"
                                                           Width="14" Height="14"
                                                           Foreground="{StaticResource BrushTextMuted}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding CashierName}"
                                           Style="{StaticResource TextBody}"
                                           FontWeight="Medium"/>
                            </StackPanel>

                            <TextBlock Grid.Row="1"
                                       Text="{Binding CurrentTime}"
                                       Style="{StaticResource TextMuted}"
                                       Margin="0,0,0,8"/>

                            <Button Grid.Row="2"
                                    Style="{StaticResource ButtonSecondary}"
                                    Padding="12,6"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding LogoutCommand}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="Logout"
                                                               Width="14" Height="14"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="Logout" FontSize="13"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Bar -->
                <Border Grid.Row="0"
                        Background="{StaticResource BrushSurface}"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="16,0">
                        <TextBlock Text="{Binding CurrentViewTitle}"
                                   Style="{StaticResource TextBody}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Button Width="32" Height="32"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource BrushTextMuted}"
                                Cursor="Hand"
                                FontSize="14"
                                HorizontalAlignment="Right"
                                Click="CloseButton_Click">✕</Button>
                    </Grid>
                </Border>

                <!-- Dynamic Content -->
                <ContentControl Grid.Row="1"
                                Content="{Binding CurrentView}"/>
            </Grid>
        </Grid>
    </Border>
</Window>