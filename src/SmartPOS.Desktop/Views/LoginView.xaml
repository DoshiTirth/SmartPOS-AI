<Window x:Class="SmartPOS.Desktop.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="SmartPOS AI — Login"
        Height="600" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="{StaticResource BrushBackground}"
            BorderBrush="{StaticResource BrushBorder}"
            BorderThickness="1"
            CornerRadius="16">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0"
                    Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0">
                    <TextBlock Text="SmartPOS AI"
                               Style="{StaticResource TextMuted}"
                               VerticalAlignment="Center"/>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Width="32" Height="32"
                            Background="Transparent"
                            Foreground="{StaticResource BrushTextMuted}"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Login Form -->
            <StackPanel Grid.Row="1"
                        VerticalAlignment="Center"
                        Margin="48,0">

                <!-- Logo / Icon -->
                <Border Width="72" Height="72"
                        Background="{StaticResource BrushAccentMuted}"
                        CornerRadius="16"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,24">
                    <iconPacks:PackIconMaterial Kind="CashRegister"
                                               Width="36" Height="36"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource BrushAccent}"/>
                </Border>

                <!-- Heading -->
                <TextBlock Text="Welcome Back"
                           Style="{StaticResource TextHeading}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <TextBlock Text="Sign in to your SmartPOS account"
                           Style="{StaticResource TextSubheading}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,36"/>

                <!-- Email -->
                <TextBlock Text="Email Address"
                           Style="{StaticResource TextMuted}"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="EmailBox"
                         Style="{StaticResource InputField}"
                         Margin="0,0,0,16"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Password -->
                <TextBlock Text="Password"
                           Style="{StaticResource TextMuted}"
                           Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox"
                             Margin="0,0,0,8"
                             Padding="12,10"
                             Background="{StaticResource BrushSurface2}"
                             Foreground="{StaticResource BrushTextPrimary}"
                             BorderBrush="{StaticResource BrushBorder}"
                             BorderThickness="1"
                             FontSize="15"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource BrushDanger}"
                           FontSize="13"
                           Margin="0,0,0,16"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>

                <!-- Login Button -->
                <Button Content="Sign In"
                        Style="{StaticResource ButtonPrimary}"
                        Height="48"
                        Margin="0,8,0,0"
                        Command="{Binding LoginCommand}"
                        IsEnabled="{Binding IsNotLoading}"/>

                <!-- Loading indicator -->
                <TextBlock Text="Signing in..."
                           Style="{StaticResource TextMuted}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

                <!-- Version -->
                <TextBlock Text="SmartPOS AI v1.0.0"
                           Style="{StaticResource TextMuted}"
                           HorizontalAlignment="Center"
                           Margin="0,32,0,0"/>

            </StackPanel>
        </Grid>
    </Border>
</Window>