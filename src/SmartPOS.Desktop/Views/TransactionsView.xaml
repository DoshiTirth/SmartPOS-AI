<UserControl x:Class="SmartPOS.Desktop.Views.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Transaction History"
                           Style="{StaticResource TextHeading}"/>
                <TextBlock Text="View and manage all POS transactions"
                           Style="{StaticResource TextSubheading}"
                           Margin="0,4,0,0"/>
            </StackPanel>
            <Button Style="{StaticResource ButtonPrimary}"
                    Padding="16,8"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Command="{Binding RefreshCommand}">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Refresh"
                                               Width="14" Height="14"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                    <TextBlock Text="Refresh" FontSize="13"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- KPI Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Total Transactions"
                               Style="{StaticResource TextMuted}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding TotalTransactions}"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontSize="28"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Total Revenue"
                               Style="{StaticResource TextMuted}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding TotalRevenue, StringFormat='${0:F2}'}"
                               Foreground="{StaticResource BrushAccent}"
                               FontSize="28"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Average Transaction"
                               Style="{StaticResource TextMuted}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding AverageTransaction, StringFormat='${0:F2}'}"
                               Foreground="{StaticResource BrushInfo}"
                               FontSize="28"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Transaction Table -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Border Grid.Row="0"
                        Background="{StaticResource BrushSurface2}"
                        CornerRadius="12,12,0,0"
                        Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Code" Style="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Cashier" Style="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="Total" Style="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="Payment" Style="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="4" Text="Status" Style="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="5" Text="Date" Style="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                    </Grid>
                </Border>

                <!-- Table Rows -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Transactions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BrushBorder}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding TransactionCode}"
                                                   Foreground="{StaticResource BrushAccent}"
                                                   FontSize="13"
                                                   FontWeight="Medium"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding CashierName}"
                                                   Style="{StaticResource TextBody}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding TotalAmount, StringFormat='${0:F2}'}"
                                                   Style="{StaticResource TextBody}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding PaymentMethod}"
                                                   Style="{StaticResource TextMuted}"/>

                                        <!-- Status Badge -->
                                        <Border Grid.Column="4"
                                                CornerRadius="4"
                                                Padding="8,3"
                                                HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource BrushAccentMuted}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Voided">
                                                            <Setter Property="Background" Value="#2A0000"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Refunded">
                                                            <Setter Property="Background" Value="#1A1A2A"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Voided">
                                                                <Setter Property="Foreground" Value="{StaticResource BrushDanger}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Refunded">
                                                                <Setter Property="Foreground" Value="{StaticResource BrushInfo}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <TextBlock Grid.Column="5"
                                                   Text="{Binding CreatedAt, StringFormat='{}{0:MMM dd, yyyy HH:mm}'}"
                                                   Style="{StaticResource TextMuted}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>