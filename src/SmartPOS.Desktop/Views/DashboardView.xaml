<UserControl x:Class="SmartPOS.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Dashboard"
                               Style="{StaticResource TextHeading}"/>
                    <TextBlock Text="Real-time overview of your store performance"
                               Style="{StaticResource TextSubheading}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Button Style="{StaticResource ButtonPrimary}"
                        Padding="16,8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Command="{Binding RefreshCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Refresh"
                                                   Width="14" Height="14"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                        <TextBlock Text="Refresh" FontSize="13"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- KPI Cards Row 1 -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Today Revenue -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <iconPacks:PackIconMaterial Kind="CurrencyUsd"
                                                       Width="16" Height="16"
                                                       Foreground="{StaticResource BrushAccent}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                            <TextBlock Text="Revenue Today"
                                       Style="{StaticResource TextMuted}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TotalRevenueToday, StringFormat='${0:F2}'}"
                                   Foreground="{StaticResource BrushAccent}"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding TotalTransactionsToday, StringFormat='{}{0} transactions'}"
                                   Style="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Border>

                <!-- Month Revenue -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,12,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <iconPacks:PackIconMaterial Kind="ChartLine"
                                                       Width="16" Height="16"
                                                       Foreground="{StaticResource BrushInfo}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                            <TextBlock Text="Revenue This Month"
                                       Style="{StaticResource TextMuted}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TotalRevenueMonth, StringFormat='${0:F2}'}"
                                   Foreground="{StaticResource BrushInfo}"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding TotalTransactionsMonth, StringFormat='{}{0} transactions'}"
                                   Style="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Border>

                <!-- Low Stock -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Margin="0,0,12,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <iconPacks:PackIconMaterial Kind="AlertCircle"
                                                       Width="16" Height="16"
                                                       Foreground="{StaticResource BrushWarning}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                            <TextBlock Text="Low Stock Alerts"
                                       Style="{StaticResource TextMuted}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding LowStockProductCount}"
                                   Foreground="{StaticResource BrushWarning}"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="products need restocking"
                                   Style="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Border>

                <!-- Anomalies -->
                <Border Grid.Column="3" Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <iconPacks:PackIconMaterial Kind="ShieldAlert"
                                                       Width="16" Height="16"
                                                       Foreground="{StaticResource BrushDanger}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                            <TextBlock Text="Unreviewed Anomalies"
                                       Style="{StaticResource TextMuted}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding UnreviewedAnomalies}"
                                   Foreground="{StaticResource BrushDanger}"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="flagged transactions"
                                   Style="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Average Transaction -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Average Transaction Value"
                                   Style="{StaticResource TextMuted}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding AverageTransactionValue, StringFormat='${0:F2}'}"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   FontSize="36"
                                   FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Store Status"
                                   Style="{StaticResource TextMuted}"
                                   Margin="0,0,0,8"/>
                        <Border Background="{StaticResource BrushAccentMuted}"
                                CornerRadius="8"
                                Padding="16,8">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="CheckCircle"
                                                           Width="16" Height="16"
                                                           Foreground="{StaticResource BrushAccent}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"/>
                                <TextBlock Text="Operational"
                                           Foreground="{StaticResource BrushAccent}"
                                           FontWeight="SemiBold"
                                           FontSize="15"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Top Selling Products -->
            <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource BrushSurface2}"
                            CornerRadius="12,12,0,0"
                            Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Top Selling Products (30 Days)"
                                       Style="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="Category"
                                       Style="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="Units Sold"
                                       Style="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="Revenue"
                                       Style="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                        </Grid>
                    </Border>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding TopProducts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BrushBorder}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding ProductName}"
                                                   Style="{StaticResource TextBody}"
                                                   FontWeight="Medium"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding CategoryName}"
                                                   Style="{StaticResource TextMuted}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding TotalUnitsSold}"
                                                   Style="{StaticResource TextBody}"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding TotalRevenue, StringFormat='${0:F2}'}"
                                                   Foreground="{StaticResource BrushAccent}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>